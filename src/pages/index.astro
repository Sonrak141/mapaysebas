---
import Layout from '../layouts/Layout.astro';
---

<Layout title="María Paula & Sebastián | Nuestra Boda">
  <!-- Top Navigation -->
  <nav class="bg-surface/80 backdrop-blur-sm fixed top-0 w-full z-50 border-b border-outline-variant/30 px-margin-page  flex justify-between items-center transition-all duration-300">
    <div class="flex items-center gap-2 select-none">
      <!-- Mini Flower next to Logo -->
      <img src="/dibujos-ms/Monogramas-Mapa-Sebas.png" alt="Flor" class="w-[5rem] object-contain opacity-85 hidden sm:block animate-pulse" />
    </div>
    <div class="hidden md:flex gap-8 items-center">
      <a class="font-label-md text-label-md text-on-surface-variant hover:text-primary transition-colors hover:font-bold" href="#nuestra-historia"> Oda a la Cotidianidad</a>
      <a class="font-label-md text-label-md text-on-surface-variant hover:text-primary transition-colors hover:font-bold" href="#donde-cuando">Detalles</a>

      <a class="font-label-md text-label-md text-on-surface-variant hover:text-primary transition-colors hover:font-bold" href="#galeria">Galería</a>
      <a class="font-label-md text-label-md text-on-surface-variant hover:text-primary transition-colors hover:font-bold" href="#qya">Q&A</a>
      <a class="bg-primary text-on-primary px-6 py-2 font-label-md text-label-md rounded-full hover:bg-primary-container transition-all shadow-sm" href="#rsvp">RSVP</a>
    </div>
    <button class="md:hidden bg-primary text-on-primary px-6 py-2 font-label-md text-label-md rounded-sm washi-tape transform rotate-1 active:scale-95 transition-transform" id="mobile-rsvp-btn">
      RSVP
    </button>
  </nav>



  <main class="overflow-hidden pt-16">
    <!-- Hero Section -->
    <section class="relative h-[85vh] md:h-[90vh] w-full overflow-hidden">
      <!-- Hero Background Image -->
      <img 
        alt="María Paula y Sebastián" 
        class="w-full h-full object-cover object-center transition-all duration-700 ease-in-out scale-100" 
        id="hero-bg-img"
        src="/fotos-preboda/pre-boda-76-banner.png"
      />
      
      <!-- Extra-large Buganvilia drawing in top right corner of Hero section (shrunk 1.5x, bleeding off edges) -->
  

      <!-- Gradient overlay -->
      <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/20 to-transparent flex flex-col justify-end items-center pb-20 text-white px-4">
        <h1 
          class="font-headline-lg text-3xl sm:text-4xl md:text-6xl mb-2 text-center drop-shadow-md collage-item-hidden" 
          data-collage="paper" 
          style="--start-rot: -5deg; --target-rot: -1deg;"
        >
          MARÍA PAULA <span class="text-secondary font-parisienne text-4xl md:text-6xl mx-2 drop-shadow-sm select-none">&</span> SEBASTIÁN
        </h1>
        <div 
          class="bg-tertiary/90 px-6 py-1.5 rounded-sm transform rotate-[-1deg] text-white font-label-md text-sm md:text-base tracking-[0.2em] uppercase drop-shadow-sm collage-item-hidden mt-2"
          data-collage="paper"
          style="--start-rot: 5deg; --target-rot: -1deg; transition-delay: 200ms;"
        >
          SÁBADO • 28 DE NOVIEMBRE
        </div>
      </div>


      <!-- Overlapping Red Flower and Guava drawings in the bottom-left corner of the Hero (as shown in the sample image) -->
 

      
    </section>

    <!-- Message from the Bride Section -->
    <section class="max-w-6xl mx-auto px-margin-page py-stack-lg relative mt-6 md:mt-0 " id="nuestra-historia">
      <!-- Watercolor Blobs -->
      <div class="absolute -top-10 left-0 watercolor-blob w-64 h-64 bg-[#fbf5d5] rounded-full"></div>
      
      <!-- Couple Drawing (Right side, elevated z-index) -->
      <div 
        class="absolute -right-20 bottom-0 w-48 md:w-64 opacity-100 hidden md:block transform collage-item-hidden z-30 pointer-events-none"
        data-collage="flower"
        style="--start-rot: 20deg; --target-rot: 6deg; --start-x: 40px;"
      >
        <img src="/dibujos-ms/pareja-sombrilla-piso-sin-fondo.png" alt="Ilustración Pareja" class="w-full h-auto drop-shadow-sm hover:rotate-12 transition-transform duration-300" />
      </div>
        <div class="absolute top-5 -left-5 w-30 z-30">
            <img src="/dibujos-ms/flor-rosa-sin-fondo.png" alt="Flor" class="w-full" />
          </div>

      <!-- 3-Column / Stack layout -->
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 items-center relative z-10">
        
        <!-- Card 1 (Left Card) -->
        <div 
          class="relative bg-surface-container-high p-8 md:px-10 md:py-16 torn-edge-bottom transform shadow-sm collage-item-hidden border border-outline-variant/10"
          data-collage="paper"
          style="--start-rot: -5deg; --target-rot: -2deg;"
        >
          <!-- Mini Flower Decoration -->
        
          
          <p class="font-handwritten text-lg md:text-xl text-on-surface-variant leading-relaxed text-center italic">
            "La verdadera promesa de nuestra boda es que sea un día inolvidable de celebración, porque estaremos acompañados de quienes amamos y hacen de nuestra cotidianidad una experiencia rica, alegre y amena.
          </p>
          <p class="font-handwritten text-lg md:text-xl text-on-surface-variant leading-relaxed text-center italic mt-4">
            Tenemos la convicción, que una vida plena - y un matrimonio feliz - se encuentra en disfrutar y valorar todos los detalles cotidianos que construyen una vida, y sobretodo, en compartir con las personas que contribuyen a que lo ordinario, se convierta en extraordinario."
          </p>
        </div>

        <!-- Center Polaroid (pre-boda-19.jpg) -->
        <div class="relative flex justify-center w-full max-w-xs mx-auto">
          <!-- Washi tape at top -->

          
          <div 
            class="polaroid w-full hover:rotate-0 transition-transform duration-300 shadow-md collage-item-hidden relative"
            data-collage="stamp"
            style="--start-rot: 8deg; --target-rot: -2deg;"
          >
            <!-- Overlay flower in corner -->

            
            <div class="bg-surface-variant w-full overflow-hidden aspect-[3/4]">
              <img src="/fotos-preboda/pre-boda-19.jpg" alt="María Paula & Sebastián Preboda" class="w-full h-full object-cover" />
            </div>

          </div>
        </div>

        <!-- Card 2 (Right Card) -->
        <div 
          class="relative bg-surface-container-high p-8 md:p-10 torn-edge-bottom transform shadow-sm collage-item-hidden border border-outline-variant/10"
          data-collage="paper"
          style="--start-rot: 5deg; --target-rot: 2deg;"
        >


          <p class="font-handwritten text-lg md:text-xl text-on-surface-variant leading-relaxed text-center italic">
            "Nos llena de alegría invitarlos a nuestra boda: una celebración a la dicha de encontrarnos, una oda que le hace honor a lo cotidiano y un recordatorio a las bendiciones que nos rodean.
          </p>
          <p class="font-handwritten text-lg md:text-xl text-on-surface-variant leading-relaxed text-center italic mt-4">
            Esta boda hace parte del compromiso de seguir construyendo en pareja lo que esperamos sea una vida larga y llena de instantes cotidianos pero maravillosos."
          </p>
          

        </div>

      </div>

      <!-- Couple Drawing Mobile layout -->
      <div 
        class="md:hidden flex justify-center mt-8 collage-item-hidden"
        data-collage="paper"
        style="--start-rot: -10deg; --target-rot: 2deg;"
      >
        <img src="/dibujos-ms/pareja-sombrilla-piso-sin-fondo.png" alt="Ilustración Pareja" class="w-48 h-auto drop-shadow-sm" />
      </div>
    </section>

    <!-- Divider Line -->
    <div class="max-w-4xl mx-auto my-4 px-margin-page flex justify-center opacity-85">
      <div class="w-full collage-item-hidden" data-collage="line">
        <img src="/dibujos-ms/linea-borde-invitacion-sin-fondo.png" alt="Divisor" class="w-full max-h-6 object-contain" />
      </div>
    </div>

    <!-- Countdown Timer Section with Faded Background Image -->
    <section class="py-20 md:py-32 px-margin-page mb-0 text-center relative overflow-hidden bg-surface z-10">
      <!-- Faded Background Image Layer (Opacity 35% to blend with soft yellow background) -->
      <div class="absolute inset-0 bg-[url('/fotos-preboda/pre-boda.jpg')] bg-cover bg-center bg-no-repeat opacity-35 z-0"></div>


      <div class="max-w-3xl mx-auto relative z-10">
        <h2 class="font-headline-lg text-3xl md:text-5xl text-primary mb-8 select-none tracking-[0.15em] uppercase font-bold">Nos vemos en...</h2>
        
        <!-- Timer Display Grid -->
        <div class="grid grid-cols-4 gap-2 sm:gap-4 md:gap-6 max-w-3xl mx-auto" id="countdown-timer">
          <div class="bg-surface-container p-2 sm:p-4 md:p-6 lg:p-8 rounded-lg shadow-md transform -rotate-1 border border-outline-variant/30 backdrop-blur-sm bg-surface-container/90 flex flex-col justify-center items-center min-w-0">
            <span class="block font-headline-lg text-3xl sm:text-5xl md:text-6xl lg:text-7xl xl:text-8xl text-primary font-bold leading-none tracking-tighter" id="timer-days">00</span>
            <span class="block text-[10px] sm:text-xs md:text-sm lg:text-base text-on-surface-variant font-label-md uppercase tracking-[0.05em] mt-1 sm:mt-2 md:mt-4">Días</span>
          </div>
          <div class="bg-surface-container p-2 sm:p-4 md:p-6 lg:p-8 rounded-lg shadow-md transform rotate-2 border border-outline-variant/30 backdrop-blur-sm bg-surface-container/90 flex flex-col justify-center items-center min-w-0">
            <span class="block font-headline-lg text-3xl sm:text-5xl md:text-6xl lg:text-7xl xl:text-8xl text-primary font-bold leading-none tracking-tighter" id="timer-hours">00</span>
            <span class="block text-[10px] sm:text-xs md:text-sm lg:text-base text-on-surface-variant font-label-md uppercase tracking-[0.05em] mt-1 sm:mt-2 md:mt-4">Horas</span>
          </div>
          <div class="bg-surface-container p-2 sm:p-4 md:p-6 lg:p-8 rounded-lg shadow-md transform -rotate-2 border border-outline-variant/30 backdrop-blur-sm bg-surface-container/90 flex flex-col justify-center items-center min-w-0">
            <span class="block font-headline-lg text-3xl sm:text-5xl md:text-6xl lg:text-7xl xl:text-8xl text-primary font-bold leading-none tracking-tighter" id="timer-minutes">00</span>
            <span class="block text-[10px] sm:text-xs md:text-sm lg:text-base text-on-surface-variant font-label-md uppercase tracking-[0.05em] mt-1 sm:mt-2 md:mt-4">Min</span>
          </div>
          <div class="bg-surface-container p-2 sm:p-4 md:p-6 lg:p-8 rounded-lg shadow-md transform rotate-1 border border-outline-variant/30 backdrop-blur-sm bg-surface-container/90 flex flex-col justify-center items-center min-w-0">
            <span class="block font-headline-lg text-3xl sm:text-5xl md:text-6xl lg:text-7xl xl:text-8xl text-primary font-bold leading-none tracking-tighter" id="timer-seconds">00</span>
            <span class="block text-[10px] sm:text-xs md:text-sm lg:text-base text-on-surface-variant font-label-md uppercase tracking-[0.05em] mt-1 sm:mt-2 md:mt-4">Seg</span>
          </div>
        </div>
      </div>
    </section>

 

    <!-- ¿Cuándo & Dónde? Section -->
    <section class="bg-surface-container-high py-stack-lg relative px-margin-page overflow-hidden" id="donde-cuando">
      <!-- Decorative Botanical Corners -->
    

      <h2 class="font-headline-lg text-[2rem] text-primary text-center mb-5">SÁBADO 28 DE NOVIEMBRE</h2>
      <div class="max-w-7xl mx-auto grid md:grid-cols-2 gap-12 items-center">
        <div class="space-y-8 relative">
          
          
          <div class="flex gap-6 items-start">
            <img src="/dibujos-ms/capilla_recortada.png" alt="Ceremonia" class="w-30 object-contain shrink-0 drop-shadow-sm" />
            <div>
              <h3 class="font-headline-md text-2xl text-tertiary font-bold">Ceremonia Religiosa</h3>
             
              <p class="font-body-md text-body-md italic text-outline mt-1 font-bold">Parroquia Santa Bibiana</p>
               <p class="font-body-lg text-body-lg text-on-surface-variant mt-1 font-bold">3:30 PM</p>
              <a class="inline-flex items-center gap-1 mt-2 text-primary font-label-md text-sm hover:underline" href="https://maps.app.goo.gl/W3yQfTYUg3TkkPF87" target="_blank">
                <span class="material-symbols-outlined text-sm">map</span> VER EN EL MAPA
              </a>
            </div>
          </div>

          <div class="flex gap-6 items-start">
            <img src="/dibujos-ms/recepcion_recortada.png" alt="Recepción" class="w-30 object-contain shrink-0 drop-shadow-sm" />
            <div>
              <h3 class="font-headline-md text-2xl text-tertiary font-bold">La Recepción</h3>
              
              <p class="font-body-md text-body-md italic text-outline mt-1 font-bold">Centro Italiano di Bogotá</p>
              <p class="font-body-lg text-body-lg text-on-surface-variant mt-1 font-bold">5:30 PM</p>
              <a class="inline-flex items-center gap-1 mt-2 text-primary font-label-md text-sm hover:underline" href="https://maps.app.goo.gl/EyHDp3aRtahwPoeT9" target="_blank">
                <span class="material-symbols-outlined text-sm">map</span> VER EN EL MAPA
              </a>
            </div>
          </div>
          
          <div class="flex gap-6 items-start">
            <img src="/dibujos-ms/codigo_recortada.png" alt="Dress Code" class="w-30 object-contain shrink-0 drop-shadow-sm" />
            <div>
              <h3 class="font-headline-md text-2xl text-tertiary font-bold">Código de Vestir</h3>
              <p class="font-body-lg text-body-lg text-on-surface-variant mt-1 font-bold">Formal</p>
              <p class="font-body-md text-body-md text-outline mt-0.5">Mujeres: Vestido Largo • Hombres: Corbata</p>
            </div>
          </div>
        </div>

        <!-- Willyz Save the Date Card -->
        <div class="relative flex justify-center w-full max-w-sm mx-auto">
          <div 
            class=" w-full max-w-sm hover:rotate-0 transition-transform duration-300  collage-item-hidden"
            data-collage="stamp"
            style="--start-rot: -12deg; --target-rot: 3deg;"
          >
 
            <div class=" w-full overflow-hidden">
              <img src="/dibujos-ms/willyz-save-the-date-sin-fondo.png" alt="Willyz Save the Date" class="w-full h-auto object-cover" />
            </div>

          </div>

        </div>
      </div>
    </section>

    <!-- Divider Line -->
    <div class="max-w-4xl mx-auto my-6 px-margin-page flex justify-center opacity-85">
      <div class="w-full collage-item-hidden" data-collage="line">
        <img src="/dibujos-ms/linea-borde-invitacion-sin-fondo.png" alt="Divisor" class="w-full max-h-6 object-contain" />
      </div>
    </div>

 



    <!-- Gallery Section -->
    <section class="py-stack-lg px-margin-page relative overflow-hidden" id="galeria">
      <div class="absolute right-10 top-20 watercolor-blob w-72 h-72 bg-secondary-container rounded-full"></div>
      
      <!-- Scrapbook Floating Flowers -->
      <div 
        class="absolute left-4 top-1/4 w-14 opacity-50 pointer-events-none hidden md:block collage-item-hidden"
        data-collage="flower"
        style="--start-rot: -45deg; --target-rot: 12deg; --start-x: -20px;"
      >
        <img src="/dibujos-ms/gerbera-sin-fondo.png" alt="Gerbera" class="w-full" />
      </div>
      <div 
        class="absolute right-10 top-1/2 w-16 opacity-50 pointer-events-none hidden md:block collage-item-hidden"
        data-collage="flower"
        style="--start-rot: 45deg; --target-rot: -12deg; --start-x: 20px;"
      >
        <img src="/dibujos-ms/guayaba-sin-fondo.png" alt="Guayaba" class="w-full" />
      </div>
      <div 
        class="absolute left-10 bottom-10 w-16 opacity-50 pointer-events-none hidden md:block collage-item-hidden"
        data-collage="flower"
        style="--start-rot: -60deg; --target-rot: 45deg; --start-x: -25px;"
      >
        <img src="/dibujos-ms/granadilla-sin-fondo.png" alt="Granadilla" class="w-full" />
      </div>

      <div class="max-w-7xl mx-auto relative z-10">
  

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8 md:gap-12 relative">
          
          <!-- Extra pressed flowers between polaroids -->
          <div 
            class="absolute top-1/3 left-1/3 w-16 z-20 pointer-events-none hidden lg:block transform collage-item-hidden"
            data-collage="flower"
            style="--start-rot: -20deg; --target-rot: -15deg; --start-y: 10px;"
          >
            <img src="/dibujos-ms/buganvilia-amarilla-sin-fondo.png" alt="Flor" class="w-full h-auto drop-shadow-sm" />
          </div>
          <div 
            class="absolute bottom-1/3 right-1/3 w-16 z-20 pointer-events-none hidden lg:block transform collage-item-hidden"
            data-collage="flower"
            style="--start-rot: 20deg; --target-rot: 25deg; --start-y: -10px;"
          >
            <img src="/dibujos-ms/orquidea-cafe-granadilla-sin-fondo.png" alt="Flor" class="w-full h-auto drop-shadow-sm" />
          </div>

          <!-- Polaroid 1 -->
          <div 
            class="polaroid hover:rotate-0 hover:scale-105 transition-all duration-300 cursor-pointer shadow-md polaroid-gallery-item collage-item-hidden" 
            data-collage="stamp"
            style="--start-rot: -15deg; --target-rot: -2deg;"
            data-full-src="/fotos-preboda/pre-boda-20.jpg" 
            data-caption="Donde todo comenzó..."
          >
            <div class="aspect-[4/5] bg-surface-variant overflow-hidden">
              <img alt="Nuestra Historia 1" class="w-full h-full object-cover lazy-img" src="/fotos-preboda/pre-boda-20.jpg" />
            </div>

          </div>

          <!-- Polaroid 2 -->
          <div 
            class="polaroid hover:rotate-0 hover:scale-105 transition-all duration-300 cursor-pointer shadow-md polaroid-gallery-item collage-item-hidden" 
            data-collage="stamp"
            style="--start-rot: 15deg; --target-rot: 2deg;"
            data-full-src="/fotos-preboda/pre-boda-22.jpg" 
            data-caption="Nuestras tardes favoritas"
          >
            <div class="aspect-[4/5] bg-surface-variant overflow-hidden">
              <img alt="Nuestra Historia 2" class="w-full h-full object-cover lazy-img" src="/fotos-preboda/pre-boda-22.jpg" />
            </div>

          </div>

          <!-- Polaroid 3 -->
          <div 
            class="polaroid hover:rotate-0 hover:scale-105 transition-all duration-300 cursor-pointer shadow-md polaroid-gallery-item collage-item-hidden" 
            data-collage="stamp"
            style="--start-rot: -10deg; --target-rot: -1deg;"
            data-full-src="/fotos-preboda/pre-boda-37.jpg" 
            data-caption="El gran 'Sí' en la montaña"
          >
            <div class="aspect-[4/5] bg-surface-variant overflow-hidden">
              <img alt="Nuestra Historia 3" class="w-full h-full object-cover lazy-img" src="/fotos-preboda/pre-boda-37.jpg" />
            </div>

          </div>

          <!-- Polaroid 4 -->
          <div 
            class="polaroid hover:rotate-0 hover:scale-105 transition-all duration-300 cursor-pointer shadow-md polaroid-gallery-item collage-item-hidden" 
            data-collage="stamp"
            style="--start-rot: 10deg; --target-rot: 1deg;"
            data-full-src="/fotos-preboda/pre-boda-45.jpg" 
            data-caption="Cómplices y compañeros de vida"
          >
            <div class="aspect-[4/5] bg-surface-variant overflow-hidden">
              <img alt="Nuestra Historia 4" class="w-full h-full object-cover lazy-img" src="/fotos-preboda/pre-boda-45.jpg" />
            </div>

          </div>

          <!-- Polaroid 5 -->
          <div 
            class="polaroid hover:rotate-0 hover:scale-105 transition-all duration-300 cursor-pointer shadow-md polaroid-gallery-item collage-item-hidden" 
            data-collage="stamp"
            style="--start-rot: -15deg; --target-rot: -3deg;"
            data-full-src="/fotos-preboda/pre-boda-72.jpg" 
            data-caption="Miradas que lo dicen todo"
          >
            <div class="aspect-[4/5] bg-surface-variant overflow-hidden">
              <img alt="Nuestra Historia 5" class="w-full h-full object-cover lazy-img" src="/fotos-preboda/pre-boda-72.jpg" />
            </div>
          </div>

          <!-- Polaroid 6 -->
          <div 
            class="polaroid hover:rotate-0 hover:scale-105 transition-all duration-300 cursor-pointer shadow-md polaroid-gallery-item collage-item-hidden" 
            data-collage="stamp"
            style="--start-rot: 15deg; --target-rot: 3deg;"
            data-full-src="/fotos-preboda/pre-boda-90.jpg" 
            data-caption="Listos para nuestra nueva aventura"
          >
            <!-- Mini flower overlaying photo card corner -->
            <img src="/dibujos-ms/gerbera-sin-fondo.png" alt="Gerbera" class="absolute -bottom-3 -right-3 w-10 z-20 transform -rotate-12 drop-shadow-sm select-none" />
            <div class="aspect-[4/5] bg-surface-variant overflow-hidden">
              <img alt="Nuestra Historia 6" class="w-full h-full object-cover lazy-img" src="/fotos-preboda/pre-boda-90.jpg" />
            </div>

          </div>
        </div>
      </div>
    </section>

    <!-- Divider Line -->
    <div class="max-w-4xl mx-auto my-6 px-margin-page flex justify-center opacity-85">
      <div class="w-full collage-item-hidden" data-collage="line">
        <img src="/dibujos-ms/linea-borde-invitacion-sin-fondo.png" alt="Divisor" class="w-full max-h-6 object-contain" />
      </div>
    </div>



    <!-- RSVP Section -->
    <section class="bg-surface-container py-stack-lg relative overflow-hidden px-margin-page" id="rsvp">
      <!-- Watercolor Blobs -->
      <div class="absolute -left-20 bottom-0 watercolor-blob w-96 h-96 bg-[#e2f0d9] rounded-full"></div>
      
      <!-- Conga guests illustration next to RSVP card (Desktop layout) -->
      <div 
        class="absolute left-10 bottom-10 w-64 opacity-90 hidden lg:block transform collage-item-hidden"
        data-collage="paper"
        style="--start-rot: -10deg; --target-rot: -3deg; --start-y: 20px;"
      >
        <img src="/dibujos-ms/invitados-conga-sin-fondo.png" alt="Invitados Celebrando" class="w-full h-auto drop-shadow-sm hover:rotate-0 transition-transform duration-300" />
      </div>
      


      <!-- Botanical Corner Details on the RSVP Card -->
      <div class="max-w-2xl mx-auto relative z-10">
        <!-- Floating flower just outside RSVP Card -->


        <div 
          class="rsvp-card p-8 md:p-12 shadow-xl transform relative collage-item-hidden"
          data-collage="paper"
          style="--start-rot: -5deg; --target-rot: 1deg;"
        >
          <!-- Inner Border Frame -->
          <div class="absolute inset-3 border border-outline-variant pointer-events-none"></div>

          <!-- Floral Card Decorations -->
          <div class="absolute -top-10 -right-10 w-25 opacity-85 select-none">
            <img src="/dibujos-ms/flor-rosa-sin-fondo.png" alt="Flor" class="w-full" />
          </div>
          <div class="absolute -bottom-3 -left-3 w-16 opacity-85 select-none">
            <img src="/dibujos-ms/gerbera-roja-sin-fondo.png" alt="Flor" class="w-full" />
          </div>

          <div class="text-center mb-8 relative z-10">
            <h2 class="font-headline-md text-headline-md text-primary mb-2 font-bold">Confirmar Asistencia</h2>
